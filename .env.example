# Discord webhook to post internships to (required).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Text placed in the message for a NEW listing so it pings people.
# Examples: @here  |  @everyone  |  <@&123456789012345678> (a role id)
# Leave blank for no mention.
DISCORD_PING=@here

# Seconds between polls (default 300 = 5 minutes).
POLL_INTERVAL_SECONDS=300

# How many of the latest internships to seed on the very first run.
INIT_COUNT=10

# How many internships to pull from the API each poll.
FETCH_LIMIT=30

# Include the full job description (collapsed behind a spoiler) in each post.
# Set to false to skip the extra per-listing fetch and keep posts compact.
INCLUDE_DESCRIPTION=true
