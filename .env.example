# ── Delivery: choose ONE mode ──────────────────────────────────────────────
# BOT MODE (recommended — adds real "Apply" buttons). Set both of these and the
# webhook below is ignored. Get the token from the Developer Portal > your app >
# Bot. Get the channel id by enabling Developer Mode in Discord, then
# right-clicking the channel > Copy Channel ID.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# WEBHOOK MODE (fallback — apply shows as a clickable link, not a button).
# Used only when DISCORD_BOT_TOKEN / DISCORD_CHANNEL_ID are blank.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Text placed in the message for a NEW listing so it pings people.
# Examples: @here  |  @everyone  |  <@&123456789012345678> (a role id)
# Leave blank for no mention.
# Note (bot mode): to ping @here/@everyone the bot needs the "Mention Everyone"
# permission in the channel; to ping a role, that role must be mentionable.
DISCORD_PING=@here

# Seconds between polls (default 300 = 5 minutes).
POLL_INTERVAL_SECONDS=300

# How many of the latest internships to seed on the very first run.
INIT_COUNT=10

# How many internships to pull from the API each poll.
FETCH_LIMIT=30

# Include the full job description (collapsed behind a spoiler) in each post.
# Set to false to skip the extra per-listing fetch and keep posts compact.
INCLUDE_DESCRIPTION=true

# ── Indeed monitor (indeed_monitor.py) ──────────────────────────────────────
# Path to a Wolveproxy-format proxy list (host:port:user:password, one per line).
# Defaults to proxies.txt in the same folder as the script.  Proxies are used
# automatically if the file exists; Indeed's Cloudflare protection may block
# direct requests from a residential or data-centre IP.
# INDEED_PROXIES_FILE=proxies.txt

# Set to false/0 to disable proxy rotation entirely (direct requests only).
# INDEED_USE_PROXIES=true
